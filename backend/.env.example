# Backend environment configuration (copy to .env and fill in values)

# App
DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]

# OpenAI
OPENAI_API_KEY=sk-...

# Firebase
FIREBASE_CERTIFICATE_JSON={"type":"service_account",...}
FIREBASE_DB_URL=https://your-project.firebaseio.com
EXPERIMENT_FEEDBACK_PATH=/survey_results

# Chat types (JSON array)
TYPES_OF_CHAT_LIST=["vanilla","Personalized Like Me"]

# Prolific
PROLIFIC_APPROVAL=your-approval-code


