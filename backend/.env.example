# Backend environment configuration (copy to .env and fill in values)

# App
DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]

# OpenAI
OPENAI_API_KEY=sk-...

# Google AI Studio (Gemma)
GOOGLE_AI_STUDIO_API_KEY=your-google-ai-studio-key
GEMMA_MODEL=gemma-4-26b-a4b-it

# Firebase
FIREBASE_CERTIFICATE_JSON={"type":"service_account",...}
FIREBASE_DB_URL=https://your-project.firebaseio.com
EXPERIMENT_FEEDBACK_PATH=/survey_results

# Chat types (JSON array)
TYPES_OF_CHAT_LIST=["Personalized Like Me","Personalized Random"]
SIMILARITY_THRESHOLD=0.92

# Prolific
PROLIFIC_APPROVAL=your-approval-code


